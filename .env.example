# 转发到下面 IMAP_USER 对应的真实收件邮箱。系统会生成 openai-xxxx@EMAIL_DOMAIN。
EMAIL_DOMAIN=
IMAP_HOST=
IMAP_PORT=
IMAP_SECURE=
IMAP_USER=
IMAP_PASS=

