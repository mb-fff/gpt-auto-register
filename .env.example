DATABASE_URL="postgresql://postgres:postgres@postgres:5432/gptar?schema=public"
PORT="3001"
REDIS_HOST="redis"
REDIS_PORT="6379"
REDIS_URL="redis://redis:6379"
JWT_SECRET="super-secret-change-me-please"

# 指纹浏览器 Provider：dolphin、hubstudio 或 bitbrowser
BROWSER_PROVIDER=dolphin
BROWSER_CDP_HOST=host.docker.internal

# Dolphin Anty Local API
DOLPHIN_API_BASE=http://host.docker.internal:3001

# Hubstudio Local API（官方默认本地端口 6873；Mac 端通常不支持 API）
HUBSTUDIO_API_BASE=http://host.docker.internal:6873
HUBSTUDIO_GROUP_CODE=
HUBSTUDIO_APP_ID=
HUBSTUDIO_APP_SECRET=

# BitBrowser 比特指纹浏览器 Local API（常见默认端口 54345）
BITBROWSER_API_BASE=http://host.docker.internal:54345

# 临时邮箱配置
# 用法：将你的域名托管到 Cloudflare，开启 Email Routing，并把 *@your-domain.com
# 转发到下面 IMAP_USER 对应的真实收件邮箱。系统会生成 openai-xxxx@EMAIL_DOMAIN。
EMAIL_DOMAIN=
IMAP_HOST=
IMAP_PORT=
IMAP_SECURE=
IMAP_USER=
IMAP_PASS=

# Cloudflare 配置（当前代码暂未直接调用 Cloudflare API，预留给后续自动检查/创建路由）
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_EMAIL_DESTINATION=

# 添加你的代理等配置
